generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String    @id @default(uuid())
  email           String    @unique
  passwordHash    String?   @map("password_hash")
  name            String
  profileImageUrl String?   @map("profile_image_url")
  provider        String    @default("local")
  providerId      String?   @map("provider_id")
  role            String    @default("user")
  emailVerified   Boolean   @default(false) @map("email_verified")
  emailVerifiedAt DateTime? @map("email_verified_at")
  fcmToken        String?   @map("fcm_token")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  orgs           Organization[] @relation("OrgCreator")
  orgMemberships OrgMember[]
  orgInvites     OrgInvite[]    @relation("OrgInviteCreator")
  rooms          Room[]         @relation("RoomCreator")
  messages       Message[]
  songs          Song[]
  contis         Conti[]
  contiShares    ContiShare[]
  history        History[]
  meditations    Meditation[]
  globalPosts    Post[]
  globalComments Comment[]
  roomReads      RoomRead[]

  @@unique([provider, providerId])
  @@map("users")
}

model Organization {
  id          String   @id @default(uuid())
  name        String
  description String?
  createdBy   String   @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  creator User        @relation("OrgCreator", fields: [createdBy], references: [id])
  members OrgMember[]
  invites OrgInvite[]
  rooms   Room[]
  history History[]

  @@map("organizations")
}

model OrgMember {
  id       String   @id @default(uuid())
  orgId    String   @map("org_id")
  userId   String   @map("user_id")
  role     String   @default("member")
  joinedAt DateTime @default(now()) @map("joined_at")

  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId])
  @@map("org_members")
}

model OrgInvite {
  id            String    @id @default(uuid())
  orgId         String    @map("org_id")
  token         String    @unique
  createdBy     String    @map("created_by")
  expiresAt     DateTime  @map("expires_at")
  usedAt        DateTime? @map("used_at")
  inviteeEmail  String?   @map("invitee_email")
  status        String    @default("pending")
  createdAt     DateTime  @default(now()) @map("created_at")

  org     Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  creator User         @relation("OrgInviteCreator", fields: [createdBy], references: [id], onDelete: Cascade)

  @@map("org_invites")
}

model Room {
  id          String   @id @default(uuid())
  orgId       String   @map("org_id")
  name        String
  description String?
  createdBy   String   @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  org         Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  creator     User          @relation("RoomCreator", fields: [createdBy], references: [id])
  messages    Message[]
  contis      Conti[]
  contiShares ContiShare[]
  reads       RoomRead[]

  @@map("rooms")
}

model RoomRead {
  roomId     String   @map("room_id")
  userId     String   @map("user_id")
  lastReadAt DateTime @default(now()) @map("last_read_at")

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([roomId, userId])
  @@map("room_reads")
}

model Message {
  id        String   @id @default(uuid())
  roomId    String   @map("room_id")
  userId    String   @map("user_id")
  content   String
  fileUrl   String?  @map("file_url")
  createdAt DateTime @default(now()) @map("created_at")

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("messages")
}

model Song {
  id            String   @id @default(uuid())
  title         String
  artist        String?
  defaultKey    String?  @map("default_key")
  tempo         Int?
  lyrics        String?
  scriptureRef  String?  @map("scripture_ref")
  sheetMusicUrl String?  @map("sheet_music_url")
  createdBy     String?  @map("created_by")
  isPublic      Boolean  @default(false) @map("is_public")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  creator    User?       @relation(fields: [createdBy], references: [id], onDelete: SetNull)
  contiSongs ContiSong[]

  @@map("songs")
}

model Conti {
  id          String    @id @default(uuid())
  title       String
  description String?
  roomId      String?   @map("room_id")
  createdBy   String    @map("created_by")
  worshipDate DateTime? @map("worship_date") @db.Date
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  room    Room?       @relation(fields: [roomId], references: [id], onDelete: SetNull)
  creator User        @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  songs   ContiSong[]
  history History[]
  shares  ContiShare[]

  @@map("contis")
}

model ContiShare {
  id       String   @id @default(uuid())
  contiId  String   @map("conti_id")
  roomId   String   @map("room_id")
  sharedBy String   @map("shared_by")
  sharedAt DateTime @default(now()) @map("shared_at")

  conti Conti @relation(fields: [contiId], references: [id], onDelete: Cascade)
  room  Room  @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [sharedBy], references: [id], onDelete: Cascade)

  @@unique([contiId, roomId])
  @@map("conti_shares")
}

model ContiSong {
  id         String  @id @default(uuid())
  contiId    String  @map("conti_id")
  songId     String  @map("song_id")
  key        String?
  tempo      Int?
  orderIndex Int     @default(0) @map("order_index")
  note       String?

  conti  Conti            @relation(fields: [contiId], references: [id], onDelete: Cascade)
  song   Song             @relation(fields: [songId], references: [id], onDelete: Cascade)
  sheets ContiSongSheet[]

  @@unique([contiId, orderIndex])
  @@map("conti_songs")
}

model ContiSongSheet {
  id          String   @id @default(uuid())
  contiSongId String   @map("conti_song_id")
  url         String
  orderIndex  Int      @default(0) @map("order_index")
  createdAt   DateTime @default(now()) @map("created_at")

  contiSong ContiSong @relation(fields: [contiSongId], references: [id], onDelete: Cascade)

  @@map("conti_song_sheets")
}

model History {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  orgId       String?   @map("org_id")
  contiId     String?   @map("conti_id")
  worshipDate DateTime? @map("worship_date") @db.Date
  createdAt   DateTime  @default(now()) @map("created_at")

  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  org   Organization? @relation(fields: [orgId], references: [id], onDelete: SetNull)
  conti Conti?        @relation(fields: [contiId], references: [id], onDelete: SetNull)

  @@map("history")
}

model Meditation {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  book      String
  chapter   Int
  verse     Int
  content   String
  note      String?
  createdAt DateTime @default(now()) @map("created_at")

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  posts Post[]

  @@map("meditations")
}

model Post {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  title        String?  @map("title")
  category     String   @default("free") @map("category")
  content      String
  fileUrl      String?  @map("file_url")
  isAnonymous  Boolean  @default(true) @map("is_anonymous")
  meditationId String?  @map("meditation_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  meditation Meditation? @relation(fields: [meditationId], references: [id], onDelete: SetNull)
  comments   Comment[]

  @@map("posts")
}

model Comment {
  id          String   @id @default(uuid())
  postId      String   @map("post_id")
  userId      String   @map("user_id")
  content     String
  isAnonymous Boolean  @default(true) @map("is_anonymous")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("comments")
}
